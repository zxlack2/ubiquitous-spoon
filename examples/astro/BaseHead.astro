---
import SpeedInsights from '@vercel/speed-insights/astro';
const { title = "Astro App", description = "Astro with Speed Insights" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
  </head>
  <body>
    <h1>Astro App with Speed Insights</h1>
    <p>This is an Astro example with Vercel Speed Insights.</p>
    <SpeedInsights />
  </body>
</html>
